<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.sample.mapper.SampleMapper">

    <insert id="insertOne">
        INSERT INTO sample (id, name, age)
        VALUES (#{id}, #{name}, #{age})
    </insert>

    <update id="updateOne">
        UPDATE sample
        SET name = #{name},
        age = #{age}
        WHERE id = #{id}
    </update>

    <delete id="deleteOne">
        DELETE FROM sample
        WHERE id = #{id}
    </delete>

</mapper>