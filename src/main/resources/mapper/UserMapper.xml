<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.appuser.mapper.AppUserMapper">

    <select id="findById" resultType="com.example.demo.appuser.dto.AppUserDto">
        select
        id,
        name
        from app_user
        where id = #{id}
    </select>

</mapper>